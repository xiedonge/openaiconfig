ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=scrypt$replace-with-generated-hash
SESSION_SECRET=replace-with-a-long-random-string

# Local development defaults to the files in the current project directory.
# Set these on the server so the site writes to the real runtime config folders.
CODEX_CONFIG_DIR=/home/your-user/.codex
OPENCLAW_CONFIG_DIR=/home/your-user/.openclaw

# Optional overrides
OPENCLAW_PROVIDER_KEY=custom-goood-my
OPENCLAW_RESTART_COMMAND=openclaw gateway restart
OPENCLAW_RESTART_TIMEOUT_MS=30000
DATA_DIR=./data
